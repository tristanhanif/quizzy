rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get user ID
    function getUserId() {
      return request.auth.uid;
    }

    // Helper function to check user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data.role;
    }

    // Users collection rules
    match /users/{userId} {
      // Users can read/write their own profiles
      allow read, write: if isAuthenticated() && getUserId() == userId;
      
      // Admin can read all users
      allow read: if isAuthenticated() && getUserRole() == 'ADMIN';
    }

    // Quizzes collection rules
    match /quizzes/{quizId} {
      // Creator can read/write their own quizzes
      allow read, write: if isAuthenticated() && 
        resource.data.creatorId == getUserId();
      
      // Anyone authenticated can read quizzes (for browsing)
      allow read: if isAuthenticated();
      
      // Creator can create quizzes
      allow create: if isAuthenticated() && 
        request.resource.data.creatorId == getUserId();
    }

    // Quiz sessions collection rules
    match /quiz_sessions/{sessionId} {
      // Creator can read/write their own sessions
      allow read, write: if isAuthenticated() && 
        resource.data.creatorId == getUserId();
      
      // Participants can read active sessions they're part of
      allow read: if isAuthenticated() && 
        getUserId() in resource.data.participants &&
        resource.data.status != 'FINISHED';
      
      // Creator can create sessions for their quizzes
      allow create: if isAuthenticated() && 
        request.resource.data.creatorId == getUserId();
      
      // Participants sub-collection
      match /participants/{participantId} {
        // Participant can read/write their own data
        allow read, write: if isAuthenticated() && 
          getUserId() == participantId;
        
        // Creator can read participant data
        allow read: if isAuthenticated() && 
          get(/databases/$(database)/documents/quiz_sessions/$(sessionId)).data.creatorId == getUserId();
      }
    }

    // Quiz results collection rules
    match /quiz_results/{resultId} {
      // Results are immutable after creation
      allow read: if isAuthenticated() && 
        (resource.data.participantId == getUserId() ||
         get(/databases/$(database)/documents/quiz_sessions/$(resource.data.sessionId)).data.creatorId == getUserId());
      
      // Only backend can create results (via admin SDK)
      allow create: if false;
      
      // No updates or deletes allowed
      allow update, delete: if false;
    }

    // Categories collection rules
    match /categories/{categoryId} {
      // Anyone authenticated can read categories
      allow read: if isAuthenticated();
      
      // Only admin can write categories
      allow write: if isAuthenticated() && getUserRole() == 'ADMIN';
    }
  }
}
